MaskedVQVAE3D(
  (encoder): PointGridEncoder(
    (patch_net): MiniPointNet(
      (mlp): Sequential(
        (0): Linear(in_features=7, out_features=128, bias=True)
        (1): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
        (2): GELU(approximate='none')
        (3): Linear(in_features=128, out_features=128, bias=True)
        (4): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
        (5): GELU(approximate='none')
      )
    )
    (proj): Linear(in_features=128, out_features=128, bias=True)
    (conv3d): Sequential(
      (0): Conv3d(128, 128, kernel_size=(3, 3, 3), stride=(1, 1, 1), padding=(1, 1, 1), bias=False)
      (1): BatchNorm3d(128, eps=1e-05, momentum=0.1, affine=True, track_running_stats=True)
      (2): GELU(approximate='none')
      (3): Conv3d(128, 128, kernel_size=(3, 3, 3), stride=(1, 1, 1), padding=(1, 1, 1), bias=False)
      (4): BatchNorm3d(128, eps=1e-05, momentum=0.1, affine=True, track_running_stats=True)
      (5): GELU(approximate='none')
    )
  )
  (masker): GeometricMasker3D(
    (scorer): Sequential(
      (0): Linear(in_features=128, out_features=64, bias=True)
      (1): GELU(approximate='none')
      (2): Linear(in_features=64, out_features=1, bias=True)
      (3): Sigmoid()
    )
    (pre_proj): Linear(in_features=128, out_features=64, bias=False)
    (class_bias): Embedding(40, 1)
    (norm): LayerNorm((128,), eps=1e-05, elementwise_affine=False)
  )
  (quantizer): VQEmbeddingEMA()
  (demasker): VolumetricDemasker3D(
    (pos_embed): Embedding(4096, 64)
    (transformer): TransformerEncoder(
      (layers): ModuleList(
        (0-2): 3 x TransformerBlock(
          (attn): MultiHeadSelfAttention(
            (norm): LayerNorm((64,), eps=1e-05, elementwise_affine=True)
            (qkv): Linear(in_features=64, out_features=192, bias=False)
            (proj): Linear(in_features=64, out_features=64, bias=True)
            (dropout): Dropout(p=0.1, inplace=False)
          )
          (ffn): FFN(
            (norm): LayerNorm((64,), eps=1e-05, elementwise_affine=True)
            (net): Sequential(
              (0): Linear(in_features=64, out_features=256, bias=True)
              (1): GELU(approximate='none')
              (2): Dropout(p=0.1, inplace=False)
              (3): Linear(in_features=256, out_features=64, bias=True)
              (4): Dropout(p=0.1, inplace=False)
            )
          )
        )
      )
      (norm): LayerNorm((64,), eps=1e-05, elementwise_affine=True)
    )
    (out_proj): Linear(in_features=64, out_features=128, bias=True)
  )
  (decoder): OccupancyDecoder(
    (mlp): Sequential(
      (0): Linear(in_features=128, out_features=256, bias=True)
      (1): GELU(approximate='none')
      (2): Dropout(p=0.0, inplace=False)
      (3): Linear(in_features=256, out_features=128, bias=True)
      (4): GELU(approximate='none')
      (5): Dropout(p=0.0, inplace=False)
      (6): Linear(in_features=128, out_features=64, bias=True)
      (7): GELU(approximate='none')
      (8): Dropout(p=0.0, inplace=False)
      (9): Linear(in_features=64, out_features=1, bias=True)
    )
  )
  (classifier): CategoryClassifierHead(
    (code_embeddings): Embedding(256, 256)
    (pos_encoder): Sequential(
      (0): Linear(in_features=3, out_features=128, bias=True)
      (1): GELU(approximate='none')
      (2): Linear(in_features=128, out_features=256, bias=True)
    )
    (spatial_attention): MultiheadAttention(
      (out_proj): NonDynamicallyQuantizableLinear(in_features=256, out_features=256, bias=True)
    )
    (attn_norm): LayerNorm((256,), eps=1e-05, elementwise_affine=True)
    (code_importance): Sequential(
      (0): Linear(in_features=256, out_features=128, bias=True)
      (1): GELU(approximate='none')
      (2): Dropout(p=0.1, inplace=False)
      (3): Linear(in_features=128, out_features=1, bias=True)
    )
    (classifier): Sequential(
      (0): LayerNorm((256,), eps=1e-05, elementwise_affine=True)
      (1): Linear(in_features=256, out_features=256, bias=True)
      (2): GELU(approximate='none')
      (3): Dropout(p=0.1, inplace=False)
      (4): Linear(in_features=256, out_features=40, bias=True)
    )
  )
  (fingerprint): GeometricFingerprintHead(
    (code_attn): Sequential(
      (0): Linear(in_features=64, out_features=32, bias=True)
      (1): Tanh()
      (2): Linear(in_features=32, out_features=1, bias=True)
    )
    (projector): Sequential(
      (0): Linear(in_features=64, out_features=128, bias=True)
      (1): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
    )
  )
)
